  ],
  "scripts": {
    "clean": "node --run clean:dist",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:dist": "node tests/smoke/import-dist-compat.mjs",
    "benchmark:compare": "npm run build --silent && node bench/compare.mjs"
  },
  "keywords": [
    "code-intelligence",
    "codegraph",
    "mcp",
    "static-analysis"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
